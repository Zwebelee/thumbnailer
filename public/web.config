xml
<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <!-- Serve index.html for client-side routes -->
    <rewrite>
      <rules>
        <rule name="SPA fallback" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <!-- Skip existing files and directories -->
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>

    <!-- Caching: short for index.html, long for static hashed assets -->
    <staticContent>
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="7.00:00:00" /> <!-- default 7 days -->
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <!-- add other mime types if needed -->
    </staticContent>

    <httpProtocol>
      <customHeaders>
        <!-- Prevent caching index.html by overriding for that file below -->
        <add name="X-Content-Type-Options" value="nosniff" />
      </customHeaders>
    </httpProtocol>

    <!-- Override caching specifically for index.html -->
    <rewrite>
      <outboundRules rewriteBeforeCache="true">
        <rule name="NoCacheIndexHtml">
          <match serverVariable="RESPONSE_Cache-Control" pattern=".*" />
          <conditions>
            <add input="{REQUEST_URI}" pattern="^/index\.html$" />
          </conditions>
          <action type="Rewrite" value="no-cache, no-store, must-revalidate" />
        </rule>
      </outboundRules>
    </rewrite>

    <!-- Optional: enable static compression and remove ETag if desired (configure in IIS UI) -->
  </system.webServer>
</configuration>
